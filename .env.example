POSTGRES_URL=postgresql://localhost

# Optional: only needed if auto-discovery can't find your saves.
# The importer automatically searches ~/Library/Containers and
# ~/Library/Application Support for OOTP Baseball saved_games directories.
# OOTP_CSV_PATH=/Users/<username>/Library/Containers/com.ootpdevelopments.ootp27macqlm/Data/Application Support/Out of the Park Developments/OOTP Baseball 27
