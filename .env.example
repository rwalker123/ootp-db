# PostgreSQL (requires a running Postgres server):
# DATABASE_URL=postgresql://postgres@localhost:5432

# SQLite (no server needed — .db files stored in db/ folder):
DATABASE_URL=sqlite

# Optional: only needed if auto-discovery can't find your saves.
# macOS: ~/Library/Application Support/Out of the Park Developments/OOTP Baseball 27
# Windows: C:\Users\<username>\Documents\Out of the Park Developments\OOTP Baseball 27
# OOTP_CSV_PATH=
